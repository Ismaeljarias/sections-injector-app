{{ 'app-base.css' | asset_url | stylesheet_tag }}
{{ 'hero-banner.css' | asset_url | stylesheet_tag }}

<div class="app-hero-banner app-hero-banner--{{ block.settings.height }} app-hero-banner--align-{{ block.settings.alignment }}" id="app-hero-{{ block.id }}" style="background-color: #f3f4f6;">
  <div class="app-hero-banner__media">
    {%- if block.settings.video_url != blank -%}
      <video
        class="app-hero-banner__video"
        autoplay
        loop
        muted
        playsinline
        aria-label="{{ block.settings.heading | escape }}"
      >
        <source src="{{ block.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif block.settings.background_image != blank -%}
      <img
        class="app-hero-banner__image"
        src="{{ block.settings.background_image | image_url: width: 1920 }}"
        srcset="
          {{ block.settings.background_image | image_url: width: 750 }} 750w,
          {{ block.settings.background_image | image_url: width: 1100 }} 1100w,
          {{ block.settings.background_image | image_url: width: 1500 }} 1500w,
          {{ block.settings.background_image | image_url: width: 1920 }} 1920w
        "
        sizes="100vw"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'app-hero-banner__image app-hero-banner__image--placeholder' }}
    {%- endif -%}

    {%- assign overlay_opacity = block.settings.overlay_opacity | plus: 0 | divided_by: 100.0 -%}
    <div class="app-hero-banner__overlay" style="opacity: {{ overlay_opacity }};">&nbsp;</div>
  </div>

  <div class="app-hero-banner__content">
    <div class="app-container">
      <div class="app-hero-banner__text">
        {%- assign heading_text = block.settings.heading | default: "Welcome to Our Store" -%}
        <h1 class="app-h1 app-hero-banner__heading">{{ heading_text }}</h1>

        {%- assign subheading_text = block.settings.subheading | default: "Discover amazing products and exceptional service" -%}
        <p class="app-hero-banner__subheading">{{ subheading_text }}</p>

        {%- if block.settings.button_text != blank and block.settings.button_link != blank -%}
          <div class="app-hero-banner__button">
            <a href="{{ block.settings.button_link }}" class="app-button app-button--primary">{{ block.settings.button_text }}</a>
          </div>
        {%- elsif block.settings.button_text != blank -%}
          <div class="app-hero-banner__button">
            <a href="#" class="app-button app-button--primary">{{ block.settings.button_text }}</a>
          </div>
        {%- else -%}
          <div class="app-hero-banner__button">
            <a href="#" class="app-button app-button--primary">Shop Now</a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero Banner",
  "target": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL",
      "info": "MP4 video URL. Will be used instead of image if provided."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 30
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Our Store"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover amazing products and exceptional service"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section Height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full", "label": "Full Screen" }
      ],
      "default": "medium"
    }
  ]
}
{% endschema %}
